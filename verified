<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="../images/salvarelogo.png">
    <title>Chimera Corp // Identity Verified</title>
    <style>
        @font-face { font-family: 'Geist'; font-style: normal; font-display: swap; font-weight: 400; src: url(../fonts/Geist-Regular.woff2) format('woff2'); }
        @font-face { font-family: 'Geist Mono'; font-style: normal; font-display: swap; font-weight: 400; src: url(../fonts/GeistMono-Regular.woff2) format('woff2'); }
        @font-face { font-family: 'Geist Pixel Square'; font-style: normal; font-display: swap; font-weight: 400; src: url(../fonts/GeistPixel-Square.woff2) format('woff2'); }
        :root {
            --bg-primary: #FEFEFE; --bg-secondary: #F8F8F8; --bg-tertiary: #F2F2F2;
            --text-primary: #212121; --text-secondary: #6B6B6B; --text-tertiary: #9A9A9A;
            --border-light: #E8E8E8; --border-medium: #D4D4D4;
            --accent-green: #00793C;
            --font-sans: 'Geist', -apple-system, BlinkMacSystemFont, sans-serif;
            --font-mono: 'Geist Mono', 'SF Mono', 'Fira Code', monospace;
            --font-pixel: 'Geist Pixel Square', 'Courier New', monospace;
        }
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        html { font-size: 16px; scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
        body { font-family: var(--font-sans); background: var(--bg-primary); color: var(--text-primary); line-height: 1.6; overflow-x: hidden; }
        a { color: inherit; text-decoration: none; }

        /* Scanline overlay */
        .texture-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; pointer-events: none; z-index: 9999; opacity: 0.045; mix-blend-mode: multiply; background-image: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(33,33,33,0.15) 2px, rgba(33,33,33,0.15) 3px); background-size: 100% 3px; }

        .page-wrapper { position: relative; z-index: 1; min-height: 100vh; display: flex; flex-direction: column; }

        /* Header */
        .header { display: flex; justify-content: space-between; align-items: center; padding: 20px 40px; border-bottom: 1px solid var(--border-light); background: rgba(254,254,254,0.85); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); }
        .header-brand { font-family: var(--font-pixel); font-size: 0.8rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
        .header-nav { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-secondary); transition: color 0.2s; }
        .header-nav:hover { color: var(--text-primary); }

        /* Clearance strip */
        .clearance-strip { display: flex; align-items: center; justify-content: center; gap: 12px; padding: 14px 40px; border-bottom: 1px solid var(--border-light); background: var(--bg-secondary); }
        .clearance-label { font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-tertiary); }
        .clearance-light { width: 8px; height: 8px; border-radius: 50%; background: var(--accent-green); animation: blink-light 3s ease-in-out infinite; }
        @keyframes blink-light { 0%, 40%, 100% { opacity: 1; } 42%, 48% { opacity: 0.3; } 50% { opacity: 1; } 75%, 78% { opacity: 0.15; } }
        .clearance-value { font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 500; color: var(--accent-green); }

        /* Main content */
        .verified-section { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 80px 40px; text-align: center; }
        .verified-status { font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent-green); margin-bottom: 32px; }
        .verified-title { font-family: var(--font-pixel); font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 400; line-height: 1.1; margin-bottom: 28px; }
        .verified-body { font-family: var(--font-sans); font-size: 0.95rem; line-height: 1.75; color: var(--text-secondary); max-width: 480px; margin-bottom: 48px; }

        /* Status block */
        .status-block { border: 1px solid var(--border-light); border-radius: 6px; overflow: hidden; max-width: 400px; width: 100%; margin-bottom: 48px; }
        .status-inner { padding: 20px 24px; background: var(--bg-secondary); font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.06em; color: var(--text-tertiary); line-height: 2.4; text-align: left; }
        .status-heading { color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.14em; }
        .status-complete { color: var(--accent-green); }
        .status-pending { color: var(--text-tertiary); }

        /* CTA button */
        .cta-link { display: inline-block; font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-tertiary); padding: 12px 24px; border: 1px solid var(--border-light); border-radius: 4px; transition: color 0.2s, border-color 0.2s, background 0.2s; }
        .cta-link:hover { color: var(--text-primary); border-color: var(--border-medium); background: var(--bg-secondary); }

        /* Protocol notice */
        .protocol { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.04em; color: var(--text-tertiary); line-height: 1.8; margin-top: 56px; max-width: 480px; text-align: left; }

        /* Footer */
        .footer { text-align: center; padding: 24px 40px; border-top: 1px solid var(--border-light); }
        .footer-text { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-tertiary); }

        /* Fade in animation */
        @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        .anim-fade-up { opacity: 0; animation: fadeUp 0.7s ease-out forwards; }
        .anim-delay-1 { animation-delay: 0.15s; }
        .anim-delay-2 { animation-delay: 0.3s; }
        .anim-delay-3 { animation-delay: 0.45s; }
        .anim-delay-4 { animation-delay: 0.6s; }
        .anim-delay-5 { animation-delay: 0.75s; }

        /* Mobile */
        @media (max-width: 768px) {
            .header { padding: 16px 20px; }
            .clearance-strip { padding: 12px 20px; }
            .verified-section { padding: 60px 24px; }
            .verified-title { font-size: clamp(1.6rem, 8vw, 2.4rem); }
        }
    </style>
</head>
<body>
    <div class="texture-overlay"></div>

    <div class="page-wrapper">

        <!-- Header -->
        <header class="header">
            <a href="https://chimeracorp.xyz" class="header-brand">The Salvare</a>
            <a href="https://chimeracorp.xyz" class="header-nav">&larr; Portal Home</a>
        </header>

        <!-- Clearance strip -->
        <div class="clearance-strip">
            <span class="clearance-label">Clearance</span>
            <div class="clearance-light"></div>
            <span class="clearance-value">Verified</span>
        </div>

        <!-- Main content -->
        <section class="verified-section">

            <div class="verified-status anim-fade-up anim-delay-1">// Authentication Complete</div>

            <h1 class="verified-title anim-fade-up anim-delay-2">Identity<br>Confirmed.</h1>

            <p class="verified-body anim-fade-up anim-delay-3">
                Your electronic mail has been authenticated and your operative credentials have been activated. You are now registered within the Chimera Corp communications network.<br><br>
                Stand by for your first classified transmission.
            </p>

            <!-- Status block -->
            <div class="status-block anim-fade-up anim-delay-4">
                <div class="status-inner">
                    <span class="status-heading">Status</span><br>
                    Identity verification&nbsp;&nbsp;.&nbsp;.&nbsp;.&nbsp;&nbsp;<span class="status-complete">Complete</span><br>
                    Operative registration&nbsp;&nbsp;.&nbsp;.&nbsp;.&nbsp;&nbsp;<span class="status-complete">Complete</span><br>
                    First transmission&nbsp;&nbsp;.&nbsp;.&nbsp;.&nbsp;.&nbsp;.&nbsp;&nbsp;<span class="status-pending">Pending</span>
                </div>
            </div>

            <!-- CTA -->
            <a href="https://chimeracorp.xyz" class="cta-link anim-fade-up anim-delay-5">Return to Chimera Corp&nbsp;&nbsp;&rarr;</a>

            <!-- Protocol notice -->
            <div class="protocol anim-fade-up anim-delay-5">
                // To prevent bots.<br>
                // This page confirms successful identity verification.<br>
                // Your operative record is now active. This cannot be undone.<br>
                // All transmissions are monitored. Act accordingly.
            </div>

        </section>

        <!-- Footer -->
        <footer class="footer">
            <span class="footer-text">&copy; The Salvare &mdash; Chimera Corp</span>
        </footer>

    </div>
</body>
</html>
